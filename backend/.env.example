APP_NAME=C-codit
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.c-codit.com
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# Either set DATABASE_URL (Render-style) OR the individual DB_* vars
DATABASE_URL=
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ccodit
DB_USERNAME=ccodit
DB_PASSWORD=

REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

SANCTUM_STATEFUL_DOMAINS=
FRONTEND_URL=https://app.c-codit.com
CORS_ALLOWED_ORIGINS=https://app.c-codit.com

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@c-codit.com"
MAIL_FROM_NAME="${APP_NAME}"

# Payment providers
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# Virtual number providers
FIVESIM_API_KEY=
FIVESIM_BASE_URL=https://5sim.net/v1
SMSACTIVATE_API_KEY=
SMSACTIVATE_BASE_URL=https://api.sms-activate.org/stubs/handler_api.php

# Platform config
PLATFORM_BASE_CURRENCY=USD
PLATFORM_MARKUP_PERCENT=15
WALLET_MAX_BALANCE=1000000
WALLET_DAILY_DEBIT_LIMIT=50000

SANCTUM_TOKEN_TTL_MINUTES=1440
SANCTUM_REFRESH_TTL_MINUTES=20160
